# Local Distributed Translation - .gitignore

# ---------- 日志文件（统一进 logs/）----------
*.log
*.log.*
logs/

# ---------- Python 环境 & 编译产物----------
.venv/
.env/
.deps/
.deps37/
__pycache__/
*.pyc
*.pyo
*.egg-info/

# ---------- 模型文件（太大，不加入 git）----------
*.gguf
*.gguf.*
llama-b9263/
llama-b9263.zip
llama-bin/

# ---------- 系统文件 ----------
.DS_Store
Thumbs.db

# ---------- Python 构建产物 ----------
dist/
build/
*.whl
*.tar.gz
*.egg

# ---------- IDE ----------
.idea/
.vscode/
*.swp
